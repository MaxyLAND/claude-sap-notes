# Credenciales SAP Universal ID usadas por me.sap.com
SAP_USER=tu.correo@empresa.com
SAP_PASS=tu_password

# Opcional: ruta persistente para la sesión (cookies). Por defecto ./storage-state.json
# SAP_STORAGE_STATE=./storage-state.json

# Opcional: poner a 1 para abrir navegador visible al depurar
# SAP_HEADFUL=0

# Opcional: timeout de navegación en ms
# SAP_NAV_TIMEOUT=45000
